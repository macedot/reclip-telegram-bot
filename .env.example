# .env.example — copy to .env and fill in real values.
# Loaded by `docker compose --env-file .env up`. docker compose treats "$"
# as a variable reference, so escape literal "$" as "$$" (see
# DASHBOARD_PASSWORD_HASH below).

# ============================================================================
# GHCR image resolution
# ============================================================================
# GitHub user/org owning the GHCR package
# (ghcr.io/${GHCR_OWNER}/reclip-telegram-bot/{reclip,bot,dashboard}).
# Set this to your fork if you've forked the repo.
GHCR_OWNER=your-ghcr-owner

# Image tag to pull. Use "latest" for released images, or pin a specific
# version. The dev/up.sh harness overrides this at launch time with the
# most recent successful "Build and Push Dev Containers" workflow tag.
IMAGE_TAG=latest

# ============================================================================
# Telegram API credentials — https://my.telegram.org
# ============================================================================
# 1. Log in with your phone number
# 2. Click "API development tools"
# 3. Create a new app (any name/description works)
# 4. Copy api_id and api_hash below
TELEGRAM_API_ID=your-api-id
TELEGRAM_API_HASH=your-api-hash

# ============================================================================
# Telegram bot token — https://t.me/BotFather
# ============================================================================
# Send /newbot to @BotFather and follow the prompts. The token looks like
# 123456789:AAGylyMZ0sLze0_8OcBHiOESQ-YY47fHlNY.
BOT_TOKEN=your-bot-token-from-botfather

# ============================================================================
# Reclip (download engine)
# ============================================================================
# URL the bot uses to reach reclip's REST API. Inside Docker, compose
# hardcodes http://reclip:8899 via the internal network — leave as is. Set
# this only when running the bot OUTSIDE Docker (e.g. local dev on host:
# RECLIP_URL=http://localhost:8899).
RECLIP_URL=http://reclip:8899

# Max parallel downloads reclip will start at once (semaphore).
MAX_CONCURRENT_DOWNLOADS=3

# Hard timeout per download job (seconds). yt-dlp is killed after this.
DOWNLOAD_TIMEOUT=900

# Max in-memory download jobs reclip tracks. Older jobs are evicted when
# the cap is reached. (Reclip persists jobs in SQLite — see RECLIP_DB_PATH
# below — so this cap now controls the DB row count, not memory.)
MAX_JOBS=1000

# Largest file size reclip will accept (yt-dlp format filter, k/m/g suffix).
# The self-hosted Telegram Bot API supports up to 2GB uploads; tighten this
# if disk space is limited.
MAX_FILESIZE=2G

# Minimum free disk space (MB) reclip requires before starting a download.
# Prevents the downloads volume from filling up.
MIN_FREE_DISK_MB=1024

# SQLite database path for reclip's persisted job store. Backed by the
# `reclip-data` Docker volume (mounted at /data). Survives container
# restarts so /api/status/<job_id> continues to work for in-flight jobs.
RECLIP_DB_PATH=/data/reclip_jobs.db

# How often the sweeper thread runs (seconds). Default = 1 hour.
SWEEP_INTERVAL_SECONDS=3600

# Job retention for done/error rows (seconds). Default = 7 days. The
# sweeper deletes rows older than this on each tick.
JOB_TTL_SECONDS=604800

# Rows stuck at status='downloading' longer than this are auto-marked
# status='error' with error='interrupted by restart'. Default = 60s.
# Set higher if you have legitimately long downloads.
STALE_DOWNLOAD_SECONDS=60

# ============================================================================
# Cleanup (bot background task)
# ============================================================================
# Files older than this are deleted on each cleanup tick.
CLEANUP_MAX_AGE_HOURS=1

# If total disk usage exceeds this (MB), oldest files are deleted first
# regardless of age, until usage drops below the threshold.
CLEANUP_MAX_DISK_MB=5000

# How often the cleanup task runs (seconds).
CLEANUP_INTERVAL_SECONDS=300

# ============================================================================
# Downloads directory
# ============================================================================
# Shared path where reclip writes downloaded files and the bot reads them
# for upload. Inside Docker this is the "downloads" volume and is hardcoded
# to /downloads in compose. Set this only when running the bot OUTSIDE Docker.
DOWNLOADS_PATH=/downloads

# ============================================================================
# Telegram user allowlist
# ============================================================================
# Comma-separated Telegram user IDs allowed to use the bot.
# FAIL-CLOSED: while both ALLOWED_USER_IDS and ALLOWED_GROUP_IDS are empty,
# the bot REJECTS every incoming message. Find your numeric ID by sending
# /start to @userinfobot.
# Example: ALLOWED_USER_IDS=123456789,987654321
ALLOWED_USER_IDS=

# Comma-separated Telegram group chat IDs whose members are all trusted.
# This is an ADDITIVE trust layer: any message originating from one of these
# chats is permitted regardless of the sender's individual user ID. Group
# membership = trust: anyone who joins the group can use the bot until you
# remove them or drop the group from this list.
# Find a group chat ID by adding @userinfobot to the group (or forwarding a
# message from it to the bot in a private chat). Group IDs are typically
# negative, e.g. -1001234567890 for supergroups.
# Example: ALLOWED_GROUP_IDS=-1001234567890,-1009876543210
ALLOWED_GROUP_IDS=

# ============================================================================
# Dashboard
# ============================================================================
# Login username. Must NOT be "admin" (rejected by dashboard code).
DASHBOARD_USER=choose-a-username

# Bcrypt hash of the dashboard login password. Generate with:
#   python -c "import bcrypt; print(bcrypt.hashpw(b'changeme', bcrypt.gensalt()).decode())"
# Paste the output below. ⚠️  Bcrypt hashes contain literal "$" signs
# (e.g. $2b$12$...) which docker compose will try to expand as variables.
# Escape every "$" as "$$" when pasting, e.g.:
#   $2b$12$abcdef...  ->  $$2b$$12$$abcdef...
DASHBOARD_PASSWORD_HASH=replace-with-real-bcrypt-hash

# Session cookie signing key (itsdangerous URLSafeTimedSerializer). Generate
# independently with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# ⚠️  Do NOT derive this from any other value (e.g. the password hash) —
# anyone who knows the hash could then forge session cookies.
DASHBOARD_SECRET_KEY=replace-with-secrets.token-urlsafe-32

# Whether to set the Secure flag on dashboard session cookies. Default true;
# set to false ONLY when running on plain HTTP inside a trusted network
# (otherwise browsers will refuse to send the cookie).
DASHBOARD_SECURE_COOKIES=true

# Internal token shared between bot and dashboard for /api/events POSTs.
# Generate independently with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# ⚠️  Do NOT reuse Telegram API ID/Hash or any other public value here.
DASHBOARD_INTERNAL_TOKEN=replace-with-shared-secret

# Max active downloads tracked in the dashboard history table. Older entries
# are evicted when the cap is reached.
MAX_ACTIVE_DOWNLOADS=256

# Dashboard login rate limit (slowapi format, e.g. "5/minute", "10/hour").
LOGIN_RATE_LIMIT=5/minute

# Host port the dashboard is published on. Change if 8080 is taken.
DASHBOARD_PORT=8080

# ============================================================================
# Reclip shared token
# ============================================================================
# Shared secret gating reclip's /api/* endpoints (the bot sends it as the
# X-Reclip-Token header). Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# ⚠️  Do NOT reuse Telegram API ID/Hash or any other public value.
# ⚠️  Same value must be set on both reclip and bot sides.
RECLIP_API_TOKEN=replace-with-shared-secret
