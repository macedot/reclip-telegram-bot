# Telegram Bot Configuration
BOT_TOKEN=your-bot-token-from-botfather

# Telegram Bot API Server (self-hosted for 2GB upload limit)
# Get these from https://my.telegram.org -> API Development Tools
TELEGRAM_API_ID=your-api-id
TELEGRAM_API_HASH=your-api-hash

# GHCR owner (required) — used to pull pre-built images
# Set this to your GitHub username/org that owns the GHCR package.
GHCR_OWNER=your-ghcr-owner
IMAGE_TAG=latest

# Reclip Configuration
RECLIP_URL=http://reclip:8899
RECLIP_HOST=0.0.0.0
RECLIP_PORT=8899
MAX_CONCURRENT_DOWNLOADS=3
DOWNLOAD_TIMEOUT=900

# Cleanup Configuration
CLEANUP_MAX_AGE_HOURS=1
CLEANUP_MAX_DISK_MB=5000
CLEANUP_INTERVAL_SECONDS=300

# Shared downloads directory (Docker volume)
DOWNLOADS_PATH=/downloads

# Telegram allowlist — comma-separated numeric Telegram user IDs.
# LEAVE EMPTY TO LOCK THE BOT OUT (fail-closed default).
# Generate one from a real Telegram account: send /start to @userinfobot
ALLOWED_USER_IDS=11111111,22222222

# Dashboard Configuration
# Admin username — required; the default "admin" is rejected by the code.
# Inside the container this becomes ADMIN_USER.
DASHBOARD_USER=choose-a-username

# Admin password — required as a bcrypt hash, not plaintext.
# Generate with:
#   python -c "import bcrypt; print(bcrypt.hashpw(b'changeme', bcrypt.gensalt()).decode())"
DASHBOARD_PASSWORD_HASH=$2b$12$replacewithrealbcrypthash

# Session signing key — required; known-insecure defaults are rejected.
# Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Inside the container this becomes SECRET_KEY.
DASHBOARD_SECRET_KEY=replace-with-secrets.token-urlsafe-32

# Set Secure flag on dashboard session cookies. Default is true; set to false only
# if you run the dashboard on plain HTTP inside a trusted network.
DASHBOARD_SECURE_COOKIES=true

# Internal token shared between bot and dashboard for /api/events.
# Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
DASHBOARD_INTERNAL_TOKEN=replace-with-shared-secret

DASHBOARD_PORT=8080

# Reclip shared token — required; gates /api/* endpoints.
# Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Must match RECLIP_API_TOKEN below (used by the bot to call reclip).
RECLIP_API_TOKEN=replace-with-shared-secret
