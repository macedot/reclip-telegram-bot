# Whitelist: deny everything by default, then allow ONLY files the reclip
# service needs at build time.
#
# The Docker build context is ./reclip (set in docker-compose.yml), so
# other services (bot/, dashboard/) and repo-root files are out of scope.

# --- deny all files (hidden + non-hidden) -----------------------------------
.*
*

# --- allow file types needed by the reclip service -------------------------
# Source code, requirements, and the rendered HTML/SVG assets that the
# Flask app serves. No CSS or JS — reclip has no static stylesheet.
!*.py
!*.txt
!*.html
!*.svg
!Dockerfile

# --- allow all directories (so patterns above can match their contents) ----
!*/

# --- explicit denies for hidden directories !*/ would otherwise re-introduce -
.vscode/
.vscode/**
.idea/
.idea/**

# --- explicit denies for paths that should never end up in the image -------
# Tests, build artifacts, secrets, IDE/OS files — none of these belong
# in a production container.
tests/
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd
.env
.env.*
*.log
*.tmp
.DS_Store
*.md